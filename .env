# Database Configuration
DATABASE_URL=sqlite:///./company.db
DATABASE_TYPE=sqlite

# AI Model Configuration
# Options: microsoft/phi-2 | TinyLlama/TinyLlama-1.1B-Chat-v1.0 | google/flan-t5-base
SLM_MODEL_NAME=google/flan-t5-base
DEVICE=cpu

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO

# Query Safety - set to true to allow only SELECT statements
SAFE_MODE=true
